      "id": 1,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "Outis",
      "dialog": "La vittoria è come garantita. La sua strategia è encomiabile.",
      "usage": "(800101, VERY_HIGH), (800102, VERY_HIGH), (800104, VERY_HIGH), (800105, VERY_HIGH)"
    },
    {
      "id": 2,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "Outis",
      "dialog": "Siamo in vantaggio. Lasciatelo a me, la prego.",
      "usage": "(800101, HIGH), (800102, HIGH), (800104, HIGH), (800105, HIGH) "
    },
    {
      "id": 3,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "Outis",
      "dialog": "Non la deluderò se dovesse mandarmi.",
      "usage": "(800101, NORMAL), (800102, NORMAL), (800104, NORMAL), (800105, NORMAL)"
    },
    {
      "id": 4,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "Outis",
      "dialog": "Nonostante il piano sia solido, temo le mie capacità non siano all'altezza.",
      "usage": "(800101, LOW), (800102, LOW), (800104, LOW), (800105, LOW)"
    },
    {
      "id": 5,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "Outis",
      "dialog": "Di chi è questa trovata schifo— Ah, era uno scherzo, non è vero?",
      "usage": "(800101, VERY_LOW), (800102, VERY_LOW), (800104, VERY_LOW), (800105, VERY_LOW) "
    },
    {
      "id": 6,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "Outis",
      "dialog": "Questa vittoria si spiega solo con il suo eccellente piano.",
      "usage": "(800101, SUCCESS), (800102, SUCCESS), (800104, SUCCESS), (800105, SUCCESS)"
    },
    {
      "id": 7,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "Outis",
      "dialog": "La colpa è mia…",
      "usage": "(800101, FAILURE), (800102, FAILURE), (800104, FAILURE), (800105, FAILURE)"
